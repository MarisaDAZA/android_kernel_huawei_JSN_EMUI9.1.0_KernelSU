 			    const struct task_security_struct *new_tsec)
 {
+   #ifdef CONFIG_KSU
+	static u32 ksu_sid;
+	char *secdata;
+	int error;
+	u32 seclen;
+   #endif
 	int nnp = (bprm->unsafe & LSM_UNSAFE_NO_NEW_PRIVS);
